# Sample environment. Copy to `.env.local` and fill in real values.
# All vars must start with VITE_ to be exposed to the client.

VITE_APP_NAME="Security Pipeline"
VITE_DATA_SOURCE=mock          # "mock" | "live"

# Dashboard backend (proxies Jenkins / DTrack / S3)
VITE_API_BASE_URL=
VITE_POLL_INTERVAL_MS=120000

# Jenkins — full URL per job (without /buildWithParameters or build number).
# Empty = no Jenkins backing (e.g. shell scripts on a VM).
# Workflow E may live on a different Jenkins instance than D.
VITE_JENKINS_BASE_URL=https://jenkins.inca.infoblox.com

# Workflow E — Build & Unit Tests
VITE_JENKINS_JOB_E_ORCHESTRATOR=
VITE_JENKINS_JOB_E_MIRROR=
VITE_JENKINS_JOB_E_NIOS_BUILD=
VITE_JENKINS_JOB_E_QUICK_UT=
VITE_JENKINS_JOB_E_SLOW_UT=

# Workflow B — SBOM & CVE Scan
VITE_JENKINS_JOB_B_EXTRACT=
VITE_JENKINS_JOB_B_DTRACK=
VITE_JENKINS_JOB_B_S3=

# Workflow D — Impact Analysis (one Jenkins pipeline drives all stages)
VITE_JENKINS_JOB_D_POLL=
VITE_JENKINS_JOB_D_INDEX=
VITE_JENKINS_JOB_D_IMPACT=
VITE_JENKINS_JOB_D_REPORT=

# Dependency-Track
VITE_DTRACK_BASE_URL=
VITE_DTRACK_PROJECT_ID=

# S3
VITE_S3_BUCKET=
VITE_S3_CVE_PREFIX=cve-output/
VITE_S3_REGION=us-east-1

# ------------------------------------------------------------------
# Server-side S3 polling (NO VITE_ prefix) — consumed by the embedded
# backend in vite-backend-plugin.ts. The poller lists this bucket/prefix
# every S3_CVE_POLL_INTERVAL_MS and tracks the newest .csv/.json object's
# lastModified. The frontend uses this signal as the gate that flips the
# SBOM/CVE workflow to "complete" and unblocks the Impact Analyser.
# Put real keys in .env.local (gitignored), never here.
# ------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-west-1
# S3_CVE_BUCKET=
# S3_CVE_PREFIX=
# S3_CVE_POLL_INTERVAL_MS=20000

# Impact Analyser
VITE_IMPACT_API_URL=
VITE_IMPACT_UI_URL=
VITE_IMPACT_AUTHOR_MODEL=
VITE_IMPACT_VERIFIER_MODEL=
# Redirect button shown in the Impact Analysis page header (defaults to UI URL)
VITE_IMPACT_REDIRECT_URL=
VITE_IMPACT_REDIRECT_LABEL=Open Impact Analyser

# ------------------------------------------------------------------
# Server-side only (NO VITE_ prefix) — consumed by vite.config.ts to
# inject Basic Auth into the dev proxy. Never shipped to the client.
# Put real values in .env.local (gitignored), not here.
# ------------------------------------------------------------------
# JENKINS_USER=
# JENKINS_API_TOKEN=
# UT_JENKINS_USER=
# UT_JENKINS_API_TOKEN=
# IMPACT_JENKINS_USER=
# IMPACT_JENKINS_API_TOKEN=
# QA2_JENKINS_USER=
# QA2_JENKINS_API_TOKEN=

# ReportPortal — bearer token for UT results (server-side proxy only)
# RP_BEARER_KEY=

# TLS verification for the Jenkins HTTPS dev proxies.
# Default: verify certs. Set to "1" ONLY if your Jenkins serves a self-signed
# or otherwise untrusted cert and you cannot install the CA locally.
# JENKINS_PROXY_TLS_INSECURE=

# Feature flags
VITE_FEAT_CONSOLE=true
VITE_FEAT_NOTIFICATIONS=true
VITE_FEAT_METRICS=true
